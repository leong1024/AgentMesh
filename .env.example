# Copy to .env and adjust. Never commit real API keys.

# --- Google Gemini / Gen AI (required for workers + orchestrator synthesis)
# LangChain reads GOOGLE_API_KEY; if you only set GEMINI_API_KEY, it is copied at runtime.
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# --- Agent service URLs (must match how Orchestrator reaches each A2A worker)
RESEARCH_A2A_URL=http://127.0.0.1:8001
CRITIC_A2A_URL=http://127.0.0.1:8002

# Each worker serves an AgentCard at this URL — also set per-agent PUBLIC_URL for the card:
RESEARCH_PUBLIC_URL=http://127.0.0.1:8001
CRITIC_PUBLIC_URL=http://127.0.0.1:8002

# LangChain unified Google Gen AI model ids (must start with google_genai:)
RESEARCH_MODEL=google_genai:gemma-4-31b-it
CRITIC_MODEL=google_genai:gemma-4-31b-it

# Orchestrator deep agent (public API + final report merge)
ORCHESTRATOR_AGENT_MODEL=google_genai:gemma-4-31b-it
ORCHESTRATOR_API_URL=http://127.0.0.1:8080

# Logging (orchestrator + agents): DEBUG, INFO, WARNING, ...
LOG_LEVEL=INFO

# Orchestrator API
API_HOST=0.0.0.0
API_PORT=8080
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
HTTP_TIMEOUT_SECONDS=600

# Optional: serve built SPA from orchestrator API (path to frontend `dist/`)
# STATIC_DIR=../frontend/dist

# Optional: override orchestrator agent listening host/port
# ORCHESTRATOR_AGENT_HOST=0.0.0.0
# ORCHESTRATOR_AGENT_PORT=8080
