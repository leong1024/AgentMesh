# Copy to .env and adjust. Never commit real API keys.

# --- Google Gemini / Gen AI (required for all three agents)
# LangChain reads GOOGLE_API_KEY; if you only set GEMINI_API_KEY, it is copied at runtime.
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# --- Agent public URLs (must match how the orchestrator reaches each agent)
RESEARCH_A2A_URL=http://127.0.0.1:8001
CRITIC_A2A_URL=http://127.0.0.1:8002
SYNTHESIZER_A2A_URL=http://127.0.0.1:8003

# Each agent serves an AgentCard at this URL — also set per-agent PUBLIC_URL for the card:
RESEARCH_PUBLIC_URL=http://127.0.0.1:8001
CRITIC_PUBLIC_URL=http://127.0.0.1:8002
SYNTHESIZER_PUBLIC_URL=http://127.0.0.1:8003

# LangChain unified Google Gen AI model ids (must start with google_genai:)
RESEARCH_MODEL=google_genai:gemma-4-31b-it
CRITIC_MODEL=google_genai:gemma-4-31b-it
SYNTHESIZER_MODEL=google_genai:gemma-4-31b-it

# Logging (orchestrator + agents): DEBUG, INFO, WARNING, ...
LOG_LEVEL=INFO

# Orchestrator API
API_HOST=0.0.0.0
API_PORT=8080
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
HTTP_TIMEOUT_SECONDS=600

# Optional: serve built SPA from orchestrator (path to frontend `dist/`)
# STATIC_DIR=../frontend/dist
